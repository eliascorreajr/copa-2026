rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == "admin@bolao.com";
    }

    function guessOwnerId(guessId) {
      return guessId.split('_match_')[0];
    }

    function isGuessOwner(guessId) {
      return signedIn() && request.auth.uid == guessOwnerId(guessId);
    }

    function validScore(score) {
      return score is int && score >= 0 && score <= 30;
    }

    function validOptionalString(value, maxLength) {
      return value == null || (value is string && value.size() <= maxLength);
    }

    function validRequiredString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }

    function validOptionalPhoto(value) {
      return value == null
        || (value is string
          && value.size() <= 120000
          && value.matches('^data:image/(jpeg|jpg|png|webp);base64,[A-Za-z0-9+/=]+$'));
    }

    function validSelfUserWrite(userId) {
      return signedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          "email", "nickname", "firstName", "lastName",
          "displayName", "photoURL", "firstAccess", "createdAt", "migratedFrom"
        ])
        && request.resource.data.email == request.auth.token.email
        && validRequiredString(request.resource.data.nickname, 80)
        && validOptionalString(request.resource.data.get("firstName", null), 80)
        && validOptionalString(request.resource.data.get("lastName", null), 120)
        && validOptionalString(request.resource.data.get("displayName", null), 220)
        && validOptionalPhoto(request.resource.data.get("photoURL", null))
        && request.resource.data.get("firstAccess", false) is bool
        && validOptionalString(request.resource.data.get("createdAt", null), 64)
        && validOptionalString(request.resource.data.get("migratedFrom", null), 128);
    }

    // Trava autoritativa POR JOGO. O id do documento e o proprio matchId.
    // Amarra matchId -> dayKey/lockAt no servidor, impedindo que o cliente
    // troque um jogo ja iniciado pelo dayKey de um dia futuro ainda aberto.
    function matchLockPath(matchId) {
      return /databases/$(database)/documents/matchLocks/$(string(matchId));
    }

    function hasMatchLock(matchId) {
      return exists(matchLockPath(matchId));
    }

    function matchLockData(matchId) {
      return get(matchLockPath(matchId)).data;
    }

    // O palpite so e valido se o dayKey/lockAt declarados forem exatamente os
    // canonicos do jogo (vindos de matchLocks), nunca um dia escolhido a dedo.
    function matchesCanonicalMatchLock(data) {
      return data.matchId is int
        && data.dayKey is string
        && data.lockAt is timestamp
        && hasMatchLock(data.matchId)
        && data.lockAt == matchLockData(data.matchId).lockAt
        && data.dayKey == matchLockData(data.matchId).dayKey;
    }

    function beforeMatchLock(data) {
      return hasMatchLock(data.matchId)
        && request.time < matchLockData(data.matchId).lockAt;
    }

    function validGuessWrite(guessId) {
      return request.resource.data.keys().hasOnly([
          "userId", "matchId", "dayKey", "lockAt", "homeTeam", "awayTeam",
          "homeScore", "awayScore", "locked", "createdAt", "updatedAt"
        ])
        && request.resource.data.userId == guessOwnerId(guessId)
        && request.resource.data.matchId is int
        && request.resource.data.homeTeam is string
        && request.resource.data.awayTeam is string
        && validScore(request.resource.data.homeScore)
        && validScore(request.resource.data.awayScore)
        && request.resource.data.locked == true
        && matchesCanonicalMatchLock(request.resource.data);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isAdmin() || validSelfUserWrite(userId);
      allow delete: if isAdmin();
    }

    match /guesses/{guessId} {
      allow read: if signedIn();
      allow create, update: if isAdmin()
        || (isGuessOwner(guessId) && validGuessWrite(guessId) && beforeMatchLock(request.resource.data));
      allow delete: if isAdmin()
        || (isGuessOwner(guessId) && beforeMatchLock(resource.data));
    }

    match /matches/{matchId} {
      allow read: if signedIn();
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }

    match /locks/{dayKey} {
      allow read: if signedIn();
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }

    match /matchLocks/{matchId} {
      allow read: if signedIn();
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }

    match /standings/{group} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /thirdPlaceRanking/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /bracketMatches/{matchId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /manualOverrides/{overrideId} {
      allow read, write: if isAdmin();
    }

    match /config/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
